flowchart TB
  %% WIP-6 v1.0 VCT Consensus Overview

  scope["WIP-6 v1.0 scope<br/>no DID · no staking contract · no GPU attestation"]

  subgraph ER["① Eligibility Check  (off-chain, per validator)"]
    direction TB
    parent["Parent block<br/>H(h-1), height h"]
    balance["Balance check<br/>Balance(h-l, a_i) >= S0"]
    key["Key binding<br/>a_i = Addr(PK_i)"]
    vrf["ECVRF proof<br/>(beta_i, pi_i) = ECVRF.Prove(SK_i, alpha)"]
    sortition{"uint256(beta_i)<br/>< P(Delta_t_eff)?"}
    skip(["Not eligible — skip round"])
  end

  subgraph POW["② Block Construction  (eligible validators only)"]
    direction TB
    seal["sealHash<br/>commit: header fields, VRF fields, ECCPoW params"]
    mine["Per-nonce message<br/>m_nu = H(VCT_MINE || sealHash || nu)"]
    sig["Mining signature<br/>sigma_nu = Sign_SK_i(m_nu)"]
    seed["ECCPoW seed<br/>powSeed_nu = H(VCT_ECCPOW || sealHash || nu || sigma_nu)"]
    eccpow["ECCPoW search<br/>find valid codeword C"]
  end

  subgraph BV["③ Block Verification  (all nodes)"]
    direction TB
    block["Candidate block<br/>(a_i, PK_i, pi_i, nu, sigma_nu, C)"]
    checks["Verifier checks<br/>1. Balance(h-l, a_i) >= S0<br/>2. Addr(PK_i) = a_i<br/>3. ECVRF.Verify(PK_i, alpha, pi_i)<br/>4. Verify_PK_i(m_nu, sigma_nu)<br/>5. ECCPoW.Verify(powSeed_nu, C)"]
    vcheck{"All 5 checks pass?"}
    accept(["Accept block"])
    reject(["Reject block"])
  end

  scope -. "scope of this spec" .-> parent

  parent --> balance --> key --> vrf --> sortition
  sortition -- "eligible" --> seal
  sortition -- "not eligible" --> skip

  seal --> mine --> sig --> seed --> eccpow --> block

  key -. "SK_i signs each nonce" .-> sig
  seal -. "sealHash binds powSeed" .-> seed

  block --> checks --> vcheck
  vcheck -- "yes" --> accept
  vcheck -- "no" --> reject

  classDef state fill:#f7f7f7,stroke:#666,stroke-width:1px,color:#111;
  classDef keynode fill:#eef1ff,stroke:#304ffe,stroke-width:1px,color:#111;
  classDef pownode fill:#fff4e6,stroke:#d97706,stroke-width:1px,color:#111;
  classDef verifynode fill:#edfff0,stroke:#16833a,stroke-width:1px,color:#111;
  classDef decision fill:#ffffff,stroke:#555,stroke-width:1.5px,color:#111;
  classDef terminal fill:#f0f0f0,stroke:#888,stroke-width:1px,color:#333;
  classDef note fill:#fffde7,stroke:#f9a825,stroke-width:1px,color:#666;

  class parent,balance,seal state;
  class key,vrf keynode;
  class mine,sig,seed,eccpow pownode;
  class block,checks verifynode;
  class sortition,vcheck decision;
  class accept,reject,skip terminal;
  class scope note;
